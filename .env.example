# ========================================
# iNephro 環境變數設定範例
# ========================================

# OpenAI API Key（必填）
VITE_OPENAI_KEY=sk-your-openai-api-key-here

# Assistants API - Assistant ID（選填，用於知識庫模式）
# 格式: asst_xxxxxxxxxx
VITE_ASSISTANT_ID=asst_your_assistant_id_here

# Upstash Redis - 雲端快取（選填，推薦）
# 從 https://console.upstash.com/ 建立資料庫後取得
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here


# ========================================
# 設定步驟
# ========================================
# 1. 複製此檔案為 .env.local
# 2. 填入你的 OpenAI API Key
# 3. (選填) 如要使用知識庫模式，填入 Assistant ID
# 4. (選填) 如要啟用雲端快取，填入 Upstash Redis 連線資訊
# 5. 重新啟動開發伺服器: npm run dev
#
